# Copy to .env.agent and fill in the two required values, then:
#   docker compose -f docker-compose.agent.yml --env-file .env.agent up -d
#
# Before starting: register this agent on the server first (web console ->
# "Add agent"), save the private key it returns as ./agent-key (chmod 600).

# Required — hostname/IP of the orion-belt server.
ORION_SERVER_HOST=

# Required — must match the machine name you registered on the server.
ORION_AGENT_NAME=

# Optional — defaults shown.
# ORION_SERVER_PORT=2222
# ORION_AGENT_ENV=production
# ORION_STRICT_HOST_KEY_CHECKING=ask
