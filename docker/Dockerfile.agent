# Build stage
FROM golang:1.26.5-alpine AS builder

RUN apk add --no-cache git make gcc musl-dev

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN make build-agent

# Agent image
FROM alpine:latest AS agent

# The agent dials out to the server over a reverse SSH tunnel and manages the
# host it runs on directly (setuid-drop to the requested local user) — it does
# not run its own sshd, so no ssh server, no local user accounts, no password
# auth. It only needs to reach the server outbound.
RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=builder /build/bin/orion-belt-agent /app/
COPY docker/agent-entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

RUN mkdir -p /etc/orion-belt

ENTRYPOINT ["/app/entrypoint.sh"]
