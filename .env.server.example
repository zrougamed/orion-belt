# Copy to .env.server and fill in the two required values, then:
#   docker compose -f docker-compose.server.yml --env-file .env.server up -d

# Required — any strong password for the bundled Postgres.
POSTGRES_PASSWORD=

# Required — generate with: openssl rand -hex 32
ORION_JWT_SECRET=

# Optional — defaults shown.
# POSTGRES_USER=orionbelt
# POSTGRES_DB=orionbelt
# ORION_SSH_PORT=2222
# ORION_API_PORT=8080
# ORION_MFA_REQUIRED=false

# Set these if exposing the console on a real domain (needed for WebAuthn/FIDO
# security keys to work — they're bound to the origin the browser sees).
# ORION_WEBAUTHN_ENABLED=true
# ORION_PUBLIC_HOST=orion.example.com
# ORION_PUBLIC_ORIGIN=https://orion.example.com

# Optional — 32-byte key (raw or base64) to encrypt session recordings at rest.
# ORION_RECORDING_ENCRYPTION_KEY=
